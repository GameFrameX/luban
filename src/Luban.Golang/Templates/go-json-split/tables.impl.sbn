{{~if __namespace != ''~}}
package {{__namespace}};
{{~end~}}
func NewTables(loader JsonLoader) (*{{__name}}, error) {
    var err error
    var buf []map[string]interface{}

    tables := &{{__name}}{}
    {{~for table in __tables ~}}
    if buf, err = loader("{{table.output_data_file}}") ; err != nil {
        return nil, err
    }
    if tables.{{table.name}}, err = New{{full_name table}}(buf) ; err != nil {
        return nil, err
    }
    {{~end~}}
    return tables, nil
}

